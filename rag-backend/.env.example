# .env.example — updated with all Person A + B Phase settings
# Copy to .env and fill in your values.

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq                          # groq | ollama
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_MODEL=llama3.2
MAX_TURNS=20

# ── EMBEDDINGS ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
HF_TOKEN=

# ── VECTOR STORE — VENDOR SELECTOR ───────────────────────────────────────────
# Switch the entire vector backend with one variable.
# Options: qdrant (default) | lancedb | chroma
VECTOR_STORE_VENDOR=qdrant

# ── QDRANT (local) ───────────────────────────────────────────────────────────
# Used when VECTOR_STORE_VENDOR=qdrant (always, for local store)
QDRANT_COLLECTION=rag_docs

# ── QDRANT CLOUD (optional — enables cloud sync) ──────────────────────────────
# Leave empty for local-only mode. Set both to enable the hybrid manager.
QDRANT_CLOUD_URL=
QDRANT_CLOUD_API_KEY=

# ── LANCEDB ───────────────────────────────────────────────────────────────────
# LANCEDB_URI is the local path (auto-created if not set)
# LANCEDB_CLOUD_URI is for LanceDB Cloud (s3:// or lancedb:// URI)
LANCEDB_URI=                               # defaults to data/lancedb/
LANCEDB_CLOUD_URI=
LANCEDB_CLOUD_API_KEY=
LANCEDB_CLOUD_REGION=

# ── CHROMADB ──────────────────────────────────────────────────────────────────
# CHROMA_PATH is the local persist path
# CHROMA_HOST activates remote/cloud mode (HttpClient)
CHROMA_PATH=                               # defaults to data/chroma/
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_API_KEY=          # only for Chroma Cloud managed; leave empty for self-hosted

# ── RETRIEVAL ─────────────────────────────────────────────────────────────────
TOP_K=20
RRF_K=60
MIN_RERANK_SCORE=0.1
OFFLINE_TOP_K=5

# ── RERANKER (Person B) ───────────────────────────────────────────────────────
# Set ENABLE_OFFLINE_RERANKER=true to apply cross-encoder in offline mode.
ENABLE_OFFLINE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2
RERANKER_TOP_K=10        # first rerank — cuts children from 20 → 10
PARENT_RERANK_TOP_K=5    # second rerank — cuts parents from 10 → 5

# ── NETWORK / SYNC ────────────────────────────────────────────────────────────
NETWORK_CHECK_URL=https://8.8.8.8
NETWORK_POLL_INTERVAL=30                   # seconds between connectivity checks
NETWORK_CHECK_TIMEOUT=3                    # HTTP timeout per check


# IS_ONLINE_OVERRIDE — dev only, never set in production
# "true"  → /health always reports is_online=true  (forces Mode 1)
# "false" → /health always reports is_online=false (forces Mode 2)
# unset   → real network probe (default)
IS_ONLINE_OVERRIDE=

# Set to your central server manifest endpoint to enable PDF sync
SYNC_MANIFEST_URL=

# ── CHUNKING ──────────────────────────────────────────────────────────────────
CHUNKER=hierarchical
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHILD_CHUNK_SIZE=512
CHILD_CHUNK_OVERLAP=80
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=100




# ── SUPABASE STORAGE ──────────────────────────────────────────────────────────
# Enables permanent public PDF storage so the sync engine can download PDFs
# on other devices after syncing vectors from the cloud store.
#
# Leave all three empty to run without Supabase (local-only mode — default).
# All existing functionality is preserved when these are empty.
#
# Setup steps:
#   1. Create a Supabase project at https://supabase.com (free tier works).
#   2. Go to Storage → New bucket → name it "pdfs" → set it to PUBLIC.
#   3. Go to Project Settings → API → copy the "service_role" key (secret!).
#      WARNING: Never commit this key to version control.
#   4. Fill in the three variables below.
#
# After setting these, every PDF ingested via POST /ingest will be uploaded
# to Supabase and its public URL will be stored in each chunk's metadata.
# When another device syncs vectors from the cloud store, the sync engine
# reads the source_url from chunk payloads and downloads the PDFs automatically.
#
SUPABASE_URL=                              # e.g. https://abcxyzabc.supabase.co
SUPABASE_SERVICE_KEY=                      # service_role key (SECRET — never share)
SUPABASE_BUCKET=pdfs                       # must match the public bucket name

# ── ADMIN PANEL AUTH ──────────────────────────────────────────────────────────
# Bearer token required to access /admin/* routes.
# Leave empty to disable auth (dev mode — all admin routes are open).
#
# To generate a secure token:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Usage — include in every admin request:
#   Authorization: Bearer <your-token>
#
# When set, an unauthorized request to any /admin/* route returns HTTP 401.
ADMIN_TOKEN=                               # set a strong random string in production